<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="003-create-lucky-draw" author="app">
        <preConditions onFail="MARK_RAN">
            <not><tableExists tableName="lucky_draw"/></not>
        </preConditions>
        <createTable tableName="lucky_draw">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="participant_name" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="sub_committee" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="status" type="VARCHAR(20)" defaultValue="PENDING">
                <constraints nullable="false"/>
            </column>
            <column name="attended_at" type="TIMESTAMP" defaultValueComputed="NOW()">
                <constraints nullable="false"/>
            </column>
            <column name="drawn_at" type="TIMESTAMP">
                <!-- nullable — only set when winner is accepted -->
            </column>
        </createTable>
    </changeSet>

</databaseChangeLog>
