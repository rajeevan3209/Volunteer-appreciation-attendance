<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="002-create-attendance" author="app">
        <preConditions onFail="MARK_RAN">
            <not><tableExists tableName="attendance"/></not>
        </preConditions>
        <createTable tableName="attendance">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="participant_name" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="sub_committee" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="marked_at" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

</databaseChangeLog>
